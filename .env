# ============================================================
# .env.example - Environment variable template
# Copy to .env and fill in your values
# ============================================================

# MongoDB connection string
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=certdb

# Backend API URL (used by Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# ML container ports (internal)
ML_HOST=ml
ML_PORT=8001

# CUDA device index (0 = first GPU, -1 = CPU)
CUDA_VISIBLE_DEVICES=0

# Tesseract binary path override (Linux: usually auto-detected)
# TESSERACT_CMD=/usr/bin/tesseract

# Poppler utilities path override (for PDF conversion on Windows)
# POPPLER_PATH=C:/Program Files/poppler/bin
